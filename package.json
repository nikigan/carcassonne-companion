{
  "name": "carcassonne-companion",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A web companion app for the board game Carcassonne to track each player's score.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
